# FastNotes configuration — copy to .env and edit. NEVER commit .env.

# ---- serving (docker-compose.yml standalone mode) ----
# FN_BIND=127.0.0.1          # 0.0.0.0 to expose directly (not recommended without TLS)
# FN_PORT=8484
# DOMAIN=notes.example.com   # for the bundled-HTTPS caddy profile

# ---- serving (docker-compose.npm.yml, existing reverse proxy) ----
# PROXY_NETWORK=nginx-proxy-manager_proxy-network

# ---- security / hardening ----
# TRUSTED_PROXIES: comma-separated IPs/CIDRs of the reverse proxy(ies) directly
# in front of FastNotes. X-Forwarded-For is honored ONLY from these exact peers;
# from anyone else it is ignored, so it can't be spoofed to evade the per-IP
# brute-force limiter. DEFAULT IS EMPTY (most secure): with no proxy trusted, the
# limiter keys on the direct connection. Behind a proxy that means every request
# shares one bucket, i.e. a single global 10-failures/5-min cap — which is fine
# for a single-master-password app.
# Set this ONLY to enable accurate per-client limiting, and set it to your
# proxy's ADDRESS, never to a whole shared range: on a shared Docker proxy
# network, trusting 172.16.0.0/12 would trust every co-tenant container and let
# it forge X-Forwarded-For. Pin to the proxy's exact container IP where possible.
# TRUSTED_PROXIES=172.18.0.2        # example: your reverse-proxy container's IP
#
# SETUP_TOKEN: optional one-time secret required for the FIRST account creation.
# Set it when the setup page is reachable from the internet before you've created
# your master password, so a stranger can't claim the instance. You'll be
# prompted for it in the browser on first run.
# SETUP_TOKEN=

# ---- AI cover generation (optional; feature is OFF while keys are empty) ----
# Bring your own key. The first configured provider is used, or force with
# LLM_PROVIDER / IMAGE_PROVIDER (anthropic|openai|gemini / higgsfield|openai|gemini|worker).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
HF_API_KEY=
HF_API_SECRET=
# LLM_MODEL=claude-haiku-4-5 | gpt-4o-mini | gemini-2.5-flash
# IMAGE_MODEL=gpt-image-1 | gemini-2.5-flash-image | <higgsfield endpoint path>
# AI_WORKER_URL=http://fastnotes-ai:7777   # only with the 'worker' profile (see README)
