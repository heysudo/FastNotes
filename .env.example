# FastNotes configuration — copy to .env and edit. NEVER commit .env.

# ---- serving (docker-compose.yml standalone mode) ----
# FN_BIND=127.0.0.1          # 0.0.0.0 to expose directly (not recommended without TLS)
# FN_PORT=8484
# DOMAIN=notes.example.com   # for the bundled-HTTPS caddy profile

# ---- serving (docker-compose.npm.yml, existing reverse proxy) ----
# PROXY_NETWORK=nginx-proxy-manager_proxy-network

# ---- AI cover generation (optional; feature is OFF while keys are empty) ----
# Bring your own key. The first configured provider is used, or force with
# LLM_PROVIDER / IMAGE_PROVIDER (anthropic|openai|gemini / higgsfield|openai|gemini|worker).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
HF_API_KEY=
HF_API_SECRET=
# LLM_MODEL=claude-haiku-4-5 | gpt-4o-mini | gemini-2.5-flash
# IMAGE_MODEL=gpt-image-1 | gemini-2.5-flash-image | <higgsfield endpoint path>
# AI_WORKER_URL=http://fastnotes-ai:7777   # only with the 'worker' profile (see README)
